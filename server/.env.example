# ── ChadWallet Go backend env ─────────────────────────────────────────
# Copy to .env for local dev (gitignored). In prod, set as host secrets.

# Port to listen on (Fly/Render inject this automatically).
PORT=8080

# Allowed CORS origin — set to your deployed frontend URL in prod.
# e.g. https://chadwallet.vercel.app   (use * for local/dev)
ALLOWED_ORIGIN=*

# BirdEye Data API key. UNSET → backend serves realistic mock data.
# Get one free at https://bds.birdeye.so
BIRDEYE_API_KEY=
# Optional: extra BirdEye keys (comma-separated), round-robined for headroom.
BIRDEYE_API_KEYS=

# Helius API key — fills real token HOLDERS (BirdEye free tier 400s on those)
# and doubles as a Solana RPC. Free at https://dashboard.helius.dev
HELIUS_API_KEY=

# Alchemy Solana RPC URL — for the live trade-execution path (balances,
# broadcasting). Optional — Helius can serve this too. https://www.alchemy.com
ALCHEMY_RPC_URL=
